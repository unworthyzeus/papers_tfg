  shorttitle = {Survey on {{UAV Cellular Communications}}},
  author = {Fotouhi, A. and Qiang, H. and Ding, M. and Hassan, M. and Giordano, L. G. and Garcia-Rodriguez, A. and Yuan, J.},
  year = {Fourthquarter 2019},
  journaltitle = {IEEE Communications Surveys Tutorials},
  volume = {21},
