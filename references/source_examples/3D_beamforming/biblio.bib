@article{Garcia-Rodriguez2019,
abstract = {What will it take for drones, and the whole associated ecosystem, to take off? Arguably, infallible C&C channels for safe and autonomous flying, and high-throughput links for multi-purpose live video streaming. And indeed, meeting these aspirations may entail full cellular support, provided through 5G-and-beyond hardware and software upgrades by both mobile operators and manufacturers of these UAVs. In this article, we vouch for massive MIMO as the key building block to realize 5G-connected UAVs. Through the sheer evidence of 3GPP-compliant simulations, we demonstrate how massive MIMO can be enhanced by complementary network-based and UAV-based solutions, resulting in consistent UAV C&C support, large UAV uplink data rates, and harmonious coexistence with legacy ground users.},
archivePrefix = {arXiv},
arxivId = {1805.05654},
author = {Garcia-Rodriguez, Adrian and Geraci, Giovanni and Lopez-Perez, David and Giordano, Lorenzo Galati and Ding, Ming and Bjornson, Emil},
doi = {10.1109/MCOM.001.1800919},
eprint = {1805.05654},
file = {:home/acolpaer/work/articles/The Essential Guide to Realizing 5G-Connected UAVs with Massive MIMO.pdf:pdf},
issn = {15581896},
journal = {IEEE Communications Magazine},
mendeley-groups = {5G NR,Beamforming,UAV},
month = {dec},
number = {12},
pages = {84--90},
publisher = {Institute of Electrical and Electronics Engineers Inc.},
title = {{The Essential Guide to Realizing 5G-Connected UAVs with Massive MIMO}},
volume = {57},
year = {2019}
}
