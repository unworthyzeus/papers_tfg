@article{Izydorczyk2020,
abstract = {High-throughput unmanned aerial vehicle (UAV) communication may unleash the true potential of novel applications for aerial vehicles but also represents a threat for cellular networks due to the high levels of generated interference. In this article, we investigate how a beamforming system installed on board a UAV can be efficiently used to ensure high-throughput uplink UAV communications with minimum impact on the services provided to users on the ground. We study two potential benefits of beamforming, namely, spatial filtering of interference and load balancing, considering different beam switching methodologies. Our analysis is based on system-level simulations followed by a series of measurement campaigns in live Long-Term Evolution (LTE) networks. Our results show that using UAV-side beamforming has a great potential to increase uplink throughput of a UAV while mitigating interference. When beamforming is used, even up to twice as many UAVs may be served within a network compared with UAVs using omni-directional antennas, assuming a constant uplink throughput target. However, to fully exploit the potential of beamforming, a standardized solution ensuring alignment between network operators and UAV manufacturers is required.},
author = {Izydorczyk, Tomasz and Berardinelli, Gilberto and Mogensen, Preben and Ginard, Michel Massanet and Wigard, Jeroen and Kovacs, Istvan Z.},
doi = {10.1109/ACCESS.2020.2991658},
file = {:home/acolpaer/work/articles/Achieving High UAV Uplink Throughput byUsing Beamforming on Board.pdf:pdf},
issn = {21693536},
journal = {IEEE Access},
keywords = {Aerial vehicles,LTE,UAV,beamforming,cellular network,interference management,uplink},
mendeley-groups = {Beamforming,UAV,4G LTE},
pages = {82528--82538},
publisher = {Institute of Electrical and Electronics Engineers Inc.},
title = {{Achieving high UAV uplink throughput by using beamforming on board}},
volume = {8},
year = {2020}
}

@article{Arshad2016,
abstract = {Network densification is foreseen as a potential solution to fulfill the 5G spectral efficiency requirements. The spectral efficiency is improved by shrinking base stations' (BSs) footprints, thus improving the spatial frequency reuse and reducing the number of users sharing the resources of each BS. However, the foreseen densification gains are achieved at the expense of increasing handover (HO) rates. Hence, HO rate is a key performance limiting factor that should be carefully considered in densification planning. This paper sheds light on the HO problem that appears in dense 5G networks and proposes an effective solution via topology aware HO skipping. Different skipping techniques are considered and compared with the conventional best connected scheme. To this end, the proposed schemes are validated via the average user rate in downlink single-tier and two-tier cellular networks, which are modeled using the Poisson point process and the Poisson cluster process, respectively. The proposed skipping schemes show up to 47% gains in the average throughput, which would maximize the benefit of network densification.},
archivePrefix = {arXiv},
arxivId = {1611.07366},
author = {Arshad, Rabe and Elsawy, Hesham and Sorour, Sameh and Al-Naffouri, Tareq Y. and Alouini, Mohamed Slim},
doi = {10.1109/ACCESS.2016.2642538},
eprint = {1611.07366},
issn = {21693536},
journal = {IEEE Access},
keywords = {Average throughput,Downlink cellular networks,Handover management,Stochastic geometry},
mendeley-groups = {Handovers,5G NR},
pages = {9073--9081},
publisher = {Institute of Electrical and Electronics Engineers Inc.},
title = {{Handover Management in 5G and Beyond: A Topology Aware Skipping Approach}},
volume = {4},
year = {2016}
}














